# Verificar privilégios de administrador
function Test-Admin {
    $currentUser = [Security.Principal.WindowsIdentity]::GetCurrent()
    $principal = New-Object Security.Principal.WindowsPrincipal($currentUser)
    return $principal.IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)
}

if (-not (Test-Admin)) {
    Write-Host "ATENÇÃO: Execute como Administrador para melhores resultados." -ForegroundColor Yellow
    Write-Host ""
}

# Função para baixar arquivos
function Download-File {
    param(
        [string]$Url,
        [string]$OutputFile
    )
    
    try {
        Write-Host "Baixando: $OutputFile..." -ForegroundColor Cyan
        $ProgressPreference = 'SilentlyContinue'
        Invoke-WebRequest -Uri $Url -OutFile $OutputFile -UseBasicParsing
        
        if ((Test-Path $OutputFile) -and ((Get-Item $OutputFile).Length -gt 0)) {
            Write-Host "✓ Download concluído: $OutputFile" -ForegroundColor Green
            return $true
        } else {
            Write-Host "✗ ERRO: Arquivo vazio ou corrompido!" -ForegroundColor Red
            return $false
        }
    }
    catch {
        Write-Host "✗ ERRO no download: $_" -ForegroundColor Red
        return $false
    }
}

# Função para executar arquivo
function Invoke-SafeExecute {
    param(
        [string]$FilePath
    )
    
    if (-not (Test-Path $FilePath)) {
        Write-Host "ERRO: Arquivo não encontrado - $FilePath" -ForegroundColor Red
        return
    }
    
    $extension = [System.IO.Path]::GetExtension($FilePath)
    
    switch ($extension.ToLower()) {
        ".exe" {
            Write-Host "Executando $FilePath..." -ForegroundColor Yellow
            Start-Process -FilePath $FilePath -Wait
        }
        ".msi" {
            Write-Host "Instalando MSI..." -ForegroundColor Yellow
            Start-Process msiexec.exe -ArgumentList "/i `"$FilePath`"" -Wait
        }
        ".zip" {
            $destFolder = [System.IO.Path]::GetFileNameWithoutExtension($FilePath)
            $destPath = Join-Path (Split-Path $FilePath) $destFolder
            
            Write-Host "Extraindo ZIP para: $destPath" -ForegroundColor Yellow
            Expand-Archive -Path $FilePath -DestinationPath $destPath -Force
            
            Write-Host "Abrindo pasta..." -ForegroundColor Green
            Start-Process explorer.exe -ArgumentList $destPath
        }
        default {
            Write-Host "Tipo de arquivo não reconhecido: $extension" -ForegroundColor Yellow
            Start-Process explorer.exe -ArgumentList (Split-Path $FilePath)
        }
    }
}

# Função para baixar múltiplos arquivos
function Download-Multiple {
    param(
        [string]$Name,
        [hashtable[]]$Files
    )
    
    Write-Host ""
    Write-Host "═══ Baixando: $Name ═══" -ForegroundColor Cyan
    
    $count = $Files.Count
    $index = 1
    
    foreach ($file in $Files) {
        Write-Host "[$index/$count] $($file.FileName)" -ForegroundColor Yellow
        
        if (Download-File -Url $file.Url -OutputFile $file.FileName) {
            Invoke-SafeExecute -FilePath (Join-Path $WorkDir $file.FileName)
        }
        
        $index++
    }
    
    Write-Host ""
    Write-Host "Abrindo pasta de downloads..." -ForegroundColor Green
    Start-Process explorer.exe -ArgumentList $WorkDir
    
    Read-Host "Pressione ENTER para continuar"
}

# Função para baixar e abrir pasta
function Download-ToFolder {
    param(
        [string]$FolderName,
        [hashtable[]]$Files
    )
    
    $destFolder = Join-Path $env:USERPROFILE "Downloads\$FolderName"
    
    if (-not (Test-Path $destFolder)) {
        New-Item -ItemType Directory -Path $destFolder -Force | Out-Null
    }
    
    Write-Host ""
    Write-Host "═══ Baixando para: $destFolder ═══" -ForegroundColor Cyan
    
    $count = $Files.Count
    $index = 1
    
    foreach ($file in $Files) {
        Write-Host "[$index/$count] Baixando $($file.FileName)..." -ForegroundColor Yellow
        
        $outputPath = Join-Path $destFolder $file.FileName
        
        if (Download-File -Url $file.Url -OutputFile $outputPath) {
            Write-Host "✓ $($file.FileName) baixado com sucesso" -ForegroundColor Green
        } else {
            Write-Host "✗ ERRO ao baixar $($file.FileName)" -ForegroundColor Red
        }
        
        $index++
    }
    
    Write-Host ""
    Write-Host "═══ Todos os arquivos em: $destFolder ═══" -ForegroundColor Green
    Start-Process explorer.exe -ArgumentList $destFolder
}

